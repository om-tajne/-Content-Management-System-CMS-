<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>CMS Dashboard</title>
    <style>
        .post-image { max-height: 300px; object-fit: cover; width: 100%; }
        .card { border: none; transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4 shadow">
        <div class="container">
            <span class="navbar-brand">🚀 Custom CMS</span>
            <div class="text-white">
                Welcome, <strong><%= user.username %></strong> (<span class="badge bg-primary"><%= user.role %></span>)
                <a href="/auth/logout" class="btn btn-outline-danger btn-sm ms-3">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <% if (user.role === 'Admin' || user.role === 'Editor') { %>
            <div class="card mb-5 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Create New Content (Text, Image, or Video)</h5>
                    <form action="/posts/create" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <input type="text" name="title" class="form-control" placeholder="Content Title" required>
                            </div>
                            <div class="col-md-6 mb-2">
                                <input type="text" name="image_url" class="form-control" placeholder="Image URL (Direct link)">
                            </div>
                        </div>
                        <textarea name="content" class="form-control mb-2" rows="3" placeholder="Write your text content here..."></textarea>
                        <input type="text" name="video_url" class="form-control mb-3" placeholder="Video URL (YouTube Embed Link)">
                        
                        <button type="submit" class="btn btn-success w-100">Publish to CMS</button>
                    </form>
                </div>
            </div>
        <% } %>

        <h3 class="mb-4">Recent Content</h3>
        <div class="row">
            <% if (posts.length === 0) { %>
                <div class="col-12 text-center text-muted">
                    <p>No content available yet. Admins and Editors can create the first post!</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h4 class="card-title text-dark"><%= post.title %></h4>
                            
                            <% if (post.image_url) { %>
                                <img src="<%= post.image_url %>" class="post-image rounded mb-3" alt="<%= post.title %>">
                            <% } %>

                            <p class="card-text text-secondary"><%= post.content %></p>

                            <% if (post.video_url) { %>
                                <div class="ratio ratio-16x9 mb-3">
                                    <iframe src="<%= post.video_url %>" title="Video content" allowfullscreen></iframe>
                                </div>
                            <% } %>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <small class="text-muted">By <strong><%= post.username %></strong></small>
                                
                                <% if (user.role === 'Admin') { %>
                                    <form action="/posts/delete/<%= post.id %>" method="POST">
                                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>